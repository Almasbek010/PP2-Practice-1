def delete_contact():
    clear()
    print("═══ Удалить контакт ═══")
    name = input("Имя контакта: ").strip()
    confirm = input(f"Удалить «{name}»? (да/нет): ").strip().lower()
    if confirm != "да":
        return

    conn = get_connection()
    cur = conn.cursor()
    try:
        cur.execute("DELETE FROM contacts WHERE name = %s", (name,))
        if cur.rowcount:
            conn.commit()
            print(f"Контакт «{name}» удалён.")
        else:
            print(f"Контакт «{name}» не найден.")
    except Exception as e:
        conn.rollback()
        print(f"Ошибка: {e}")
    finally:
        cur.close(); conn.close()
    input("\nEnter для продолжения...")



