import sys
import random
import pygame
 
from racer import (
    Road, PlayerCar, EnemyCar, Obstacle, Coin, PowerUp, NitroStrip,
    WIN_W, WIN_H, LANE_COUNT,
    BASE_ROAD_SPEED, NITRO_BONUS, DIFFICULTY_SPEEDS,
    PU_NITRO, PU_SHIELD, PU_REPAIR,
)
from ui import (
    screen_main_menu, screen_leaderboard,
    screen_settings, screen_game_over, draw_hud,
)
from persistence import load_settings, add_score

DIFF_ENEMY_INTERVAL = {"easy": 3000, "normal": 2000, "hard": 1200}
DIFF_OBS_INTERVAL   = {"easy": 4000, "normal": 2800, "hard": 1800}
DIFF_PU_INTERVAL    = {"easy": 6000, "normal": 9000, "hard": 12000}
 

def run_game(screen, clock, fonts, username, settings):
    diff       = settings.get("difficulty", "normal")
    car_color  = tuple(settings.get("car_color", [0, 120, 255]))
 
    road    = Road()
    player  = PlayerCar(car_color)
 
    enemies   = []
    obstacles = []
    coins     = []
    powerups  = []
    strips    = []
 
    score    = 0
    distance = 0
    coin_count = 0
 
    active_pu   = None
    pu_end_time = 0
 
    road_speed  = DIFFICULTY_SPEEDS.get(diff, 5)
    base_speed  = road_speed

    now = pygame.time.get_ticks
    last_enemy   = now()
    last_obs     = now()
    last_coin    = now()
    last_pu      = now()
    last_strip   = now()
    last_scale   = now()
 
    enemy_interval = DIFF_ENEMY_INTERVAL[diff]
    obs_interval   = DIFF_OBS_INTERVAL[diff]
    pu_interval    = DIFF_PU_INTERVAL[diff]
 
    key_cooldown = 0
 
    running = True
    while running:
        dt  = clock.tick(60)
        t   = now()

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                return score, distance, coin_count
            if event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:
                return score, distance, coin_count

        keys = pygame.key.get_pressed()
        if t > key_cooldown:
            if keys[pygame.K_LEFT] or keys[pygame.K_a]:
                player.move_left()
                key_cooldown = t + 180
            elif keys[pygame.K_RIGHT] or keys[pygame.K_d]:
                player.move_right()
                key_cooldown = t + 180

        road_speed = base_speed + (NITRO_BONUS if player.nitro else 0)

        if t - last_scale > 10000:
            last_scale = t
            base_speed      = min(base_speed + 1, 18)
            enemy_interval  = max(enemy_interval - 100, 600)
            obs_interval    = max(obs_interval - 100, 800)

        if t - last_enemy > enemy_interval:
            last_enemy = t
            lane = random.choice(
                [l for l in range(LANE_COUNT) if l != player.lane]
                or list(range(LANE_COUNT))
            )
            e = EnemyCar(random.randint(1, 3))
            e.lane = lane
            from racer import lane_center_x
            e.x = float(lane_center_x(lane))
            enemies.append(e)

        if t - last_obs > obs_interval:
            last_obs = t
            if random.random() < 0.7:
                obstacles.append(Obstacle())

        if t - last_coin > 1200:
            last_coin = t
            if random.random() < 0.8:
                coins.append(Coin())

        if t - last_pu > pu_interval:
            last_pu = t
            if not powerups:
                powerups.append(PowerUp())

        if t - last_strip > 8000:
            last_strip = t
            if random.random() < 0.4:
                strips.append(NitroStrip())

        if active_pu and active_pu != PU_SHIELD and t > pu_end_time:
            active_pu = None

        road.update(road_speed)
        player.update()
 
        for e in enemies:
            e.update(road_speed)
        enemies = [e for e in enemies if not e.is_off_screen()]
 
        for o in obstacles:
            o.update(road_speed)
        obstacles = [o for o in obstacles if not o.is_off_screen()]
 
        for c in coins:
            c.update(road_speed)
        coins = [c for c in coins if not c.is_off_screen()]
 
        for p in powerups:
            p.update(road_speed)
        powerups = [p for p in powerups if not p.is_off_screen() and not p.is_expired()]
 
        for s in strips:
            s.update(road_speed)
        strips = [s for s in strips if not s.is_off_screen()]

        distance += road_speed // 5
        score    += road_speed // 10

        pr = player.rect
        for e in enemies[:]:
            if pr.colliderect(e.rect):
                dead = player.take_hit()
                enemies.remove(e)
                if dead:
                    running = False

        for o in obstacles[:]:
            if pr.colliderect(o.rect):
                if o.kind == "oil":
                    # Масло — замедляем
                    base_speed = max(2, base_speed - 1)
                else:
                    dead = player.take_hit()
                    if dead:
                        running = False
                obstacles.remove(o)

        for c in coins[:]:
            if pr.colliderect(c.rect):
                score      += c.value * 10
                coin_count += c.value
                coins.remove(c)

        for p in powerups[:]:
            if pr.colliderect(p.rect):
                kind = p.kind
                powerups.remove(p)
                active_pu = kind
                if kind == PU_NITRO:
                    pu_end_time = t + 4000
                    player.activate_nitro(4000)
                elif kind == PU_SHIELD:
                    player.activate_shield()
                    pu_end_time = t + 999999
                elif kind == PU_REPAIR:
                    if obstacles:
                        obstacles.pop(0)
                    active_pu   = None

        for s in strips[:]:
            if pr.colliderect(s.rect):
                player.activate_nitro(3000)
                active_pu   = PU_NITRO
                pu_end_time = t + 3000
                strips.remove(s)

        road.draw(screen)
 
        for s in strips:
            s.draw(screen)
        for o in obstacles:
            o.draw(screen)
        for c in coins:
            c.draw(screen)
        for p in powerups:
            p.draw(screen)
        for e in enemies:
            e.draw(screen)
        player.draw(screen)
 
        draw_hud(screen, fonts, score, distance, coin_count,
                 active_pu, pu_end_time, player.shield)
 
        pygame.display.flip()
 
    return score, distance, coin_count
 

def main():
    pygame.init()
    screen = pygame.display.set_mode((WIN_W, WIN_H))
    pygame.display.set_caption("RACER — TSIS 3")
    clock  = pygame.time.Clock()
 
    fonts = {
        "big":   pygame.font.SysFont("Arial", 52, bold=True),
        "mid":   pygame.font.SysFont("Arial", 28),
        "small": pygame.font.SysFont("Arial", 18),
    }
 
    settings = load_settings()
 
    while True:
        result = screen_main_menu(screen, clock, fonts)
 
        if result[0] == "quit":
            break
 
        elif result[0] == "leaderboard":
            screen_leaderboard(screen, clock, fonts)
 
        elif result[0] == "settings":
            settings = screen_settings(screen, clock, fonts, settings)
 
        elif result[0] == "play":
            username = result[1]
 
            while True:
                score, distance, coins = run_game(
                    screen, clock, fonts, username, settings
                )
 
                # Сохраняем результат
                add_score(username, score, distance, coins)
 
                action = screen_game_over(
                    screen, clock, fonts, score, distance, coins
                )
 
                if action == "retry":
                    continue
                elif action == "menu":
                    break
                else:
                    pygame.quit()
                    sys.exit()
 
    pygame.quit()
    sys.exit()
 
 
if __name__ == "__main__":
    main()